# ===== ОБЯЗАТЕЛЬНЫЕ ТОКЕНЫ =====

# Telegram Bot Token (получить у @BotFather в Telegram)
TG_BOT_TOKEN=your_telegram_bot_token_here

# Max Bot Token (получить на business.max.ru → Чат-боты → Интеграция → Получить токен)
MAX_BOT_TOKEN=your_max_bot_token_here

# ===== URL КОНФИГУРАТОРА =====

# URL где размещён конфигуратор (GitHub Pages)
CONFIGURATOR_URL=https://aihrtest-create.github.io/planner-park/

# ===== СЕРВЕР =====

# Порт сервера
PORT=3001

# URL сервера (для webhook'ов ботов, нужен HTTPS!)
# Для локальной разработки можно использовать ngrok
SERVER_URL=https://your-server.railway.app

# ===== БЕЗОПАСНОСТЬ =====

# Пароль для входа в менеджерскую панель
DASHBOARD_PASSWORD=admin123

# Секрет для API-ключа (для защиты API от посторонних)
API_SECRET=change_me_to_random_string
